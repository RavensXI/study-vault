{
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/pipeline/parse.js": {
      "maxDuration": 60
    },
    "api/pipeline/regenerate-diagram.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/lesson/:subject/:unit/:number", "destination": "/lesson.html" },
    { "source": "/browse/:subject/:unit", "destination": "/browse.html" },
    { "source": "/browse/:subject", "destination": "/browse.html" },
    { "source": "/guide/:subject/:type/:slug", "destination": "/guide.html" },
    { "source": "/guide/:subject/:type", "destination": "/guide.html" },
    { "source": "/admin/review", "destination": "/admin/review.html" },
    { "source": "/admin/pipeline", "destination": "/admin/pipeline.html" },
    { "source": "/admin/images", "destination": "/admin/images.html" },
    { "source": "/admin/editor", "destination": "/admin/editor.html" },
    { "source": "/teacher/dashboard", "destination": "/teacher/dashboard.html" }
  ]
}
